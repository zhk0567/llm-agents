# Copy to .env and adjust. All paths are relative to project root.
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_API_KEY=ollama
OLLAMA_MODEL=nemotron-3-super:cloud

# Set by scripts/setup-ollama.ps1 (models stored in project)
# OLLAMA_MODELS=<project>/models/ollama

# 1 = mock search (default), 0 = DuckDuckGo (pip install duckduckgo-search)
USE_MOCK_SEARCH=1
