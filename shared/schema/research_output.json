{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/zhk0567/llm-agents/research_output.json",
  "title": "TopicResearchAgentOutput",
  "type": "object",
  "required": ["topic", "bullets", "summary"],
  "additionalProperties": true,
  "properties": {
    "topic": {
      "type": "string",
      "minLength": 1
    },
    "bullets": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1,
      "maxItems": 10
    },
    "summary": {
      "type": "string",
      "minLength": 1
    }
  }
}
